{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.vue",
    "./**/*.d.ts"
  ],
  "exclude": [
    "./app/**/*",
    "./**/*.tsx",
    "./main.tsx"
  ]
}
