page {
  background-color: #f3f4f6;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.5;
}
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  border: none;
}
.btn-primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #fff;
}
.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}
.btn-secondary {
  background: #f3f4f6;
  color: #1f2937;
}
.btn-secondary:active {
  background: #f9fafb;
}
.btn-outline {
  background: transparent;
  border: 2rpx solid #3b82f6;
  color: #3b82f6;
}
.btn-outline:active {
  background: rgba(59, 130, 246, 0.1);
}
.btn-block {
  width: 100%;
}
.btn-lg {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}
.text-primary {
  color: #3b82f6;
}
.text-secondary {
  color: #6b7280;
}
.text-muted {
  color: #9ca3af;
}
.text-success {
  color: #10b981;
}
.text-warning {
  color: #f59e0b;
}
.text-danger {
  color: #ef4444;
}
.flex {
  display: flex;
}
.flex-col {
  flex-direction: column;
}
.items-center {
  align-items: center;
}
.justify-center {
  justify-content: center;
}
.justify-between {
  justify-content: space-between;
}
.gap-xs {
  gap: 8rpx;
}
.gap-sm {
  gap: 16rpx;
}
.gap-md {
  gap: 24rpx;
}
.flex-1 {
  flex: 1;
}
.font-bold {
  font-weight: 700;
}
.font-semibold {
  font-weight: 600;
}
.text-center {
  text-align: center;
}
.text-right {
  text-align: right;
}
.w-full {
  width: 100%;
}
.mt-sm {
  margin-top: 16rpx;
}
.mt-md {
  margin-top: 24rpx;
}
.mb-sm {
  margin-bottom: 16rpx;
}
.mb-md {
  margin-bottom: 24rpx;
}
.overflow-hidden {
  overflow: hidden;
}
.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
