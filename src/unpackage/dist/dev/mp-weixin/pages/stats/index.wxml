<view class="page data-v-1fa681a1"><text class="page-title data-v-1fa681a1">数据统计</text><view class="grid data-v-1fa681a1"><view class="metric data-v-1fa681a1"><text class="metric-icon data-v-1fa681a1">🕒</text><text class="metric-value data-v-1fa681a1">{{a}}</text><text class="metric-label data-v-1fa681a1">累计分钟</text></view><view class="metric data-v-1fa681a1"><text class="metric-icon data-v-1fa681a1">🎯</text><text class="metric-value data-v-1fa681a1">{{b}}</text><text class="metric-label data-v-1fa681a1">完成任务</text></view><view class="metric data-v-1fa681a1"><text class="metric-icon data-v-1fa681a1">🏆</text><text class="metric-value data-v-1fa681a1">{{c}}</text><text class="metric-label data-v-1fa681a1">累计积分</text></view><view class="metric data-v-1fa681a1"><text class="metric-icon data-v-1fa681a1">🎖️</text><text class="metric-value data-v-1fa681a1">{{d}}</text><text class="metric-label data-v-1fa681a1">今日积分</text></view></view><view class="card data-v-1fa681a1"><text class="card-title data-v-1fa681a1">本周专注时长</text><view class="trend data-v-1fa681a1"><view wx:for="{{e}}" wx:for-item="day" wx:key="d" class="day data-v-1fa681a1"><view class="bar data-v-1fa681a1"><view class="fill data-v-1fa681a1" style="{{'height:' + day.a + ';' + ('background:' + day.b)}}"></view></view><text class="day-label data-v-1fa681a1">{{day.c}}</text></view></view></view><view class="card data-v-1fa681a1"><text class="card-title data-v-1fa681a1">今日记录</text><view wx:if="{{f}}" class="empty data-v-1fa681a1"><text class="empty-icon data-v-1fa681a1">🕒</text><text class="empty-text data-v-1fa681a1">还没有完成任何专注任务</text><text class="empty-sub data-v-1fa681a1">开始第一个专注吧！</text></view><view wx:else class="history data-v-1fa681a1"><view wx:for="{{g}}" wx:for-item="session" wx:key="g" class="history-item data-v-1fa681a1"><view class="history-left data-v-1fa681a1"><view class="history-icon data-v-1fa681a1" style="{{'background:' + session.b}}">{{session.a}}</view><view class="history-info data-v-1fa681a1"><text class="history-name data-v-1fa681a1">{{session.c}}</text><text class="history-time data-v-1fa681a1">{{session.d}}</text></view></view><view class="history-right data-v-1fa681a1"><text class="history-points data-v-1fa681a1">+{{session.e}}</text><text class="history-duration data-v-1fa681a1">{{session.f}}分钟</text></view></view><button class="more-btn data-v-1fa681a1" bindtap="{{h}}">查看全部</button></view></view></view>