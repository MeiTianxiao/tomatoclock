/* 烟花特效 */
.fireworks-container.data-v-4978fed5 {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
}
.celebration-text.data-v-4978fed5 {
  font-size: 48rpx;
  font-weight: bold;
  color: #f59e0b;
  text-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
  animation: popIn-4978fed5 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}
.firework.data-v-4978fed5 {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  box-shadow: 0 0 #ef4444, 0 0 #3b82f6, 0 0 #10b981, 0 0 #f59e0b, 0 0 #8b5cf6, 0 0 #ec4899, 0 0 #06b6d4, 0 0 #f43f5e;
  animation: explode-4978fed5 1s ease-out infinite;
}
.firework.data-v-4978fed5:nth-child(1) {
  top: 30%;
  left: 30%;
  animation-delay: 0s;
}
.firework.data-v-4978fed5:nth-child(2) {
  top: 40%;
  left: 70%;
  animation-delay: 0.2s;
}
.firework.data-v-4978fed5:nth-child(3) {
  top: 60%;
  left: 40%;
  animation-delay: 0.4s;
}
.firework.data-v-4978fed5:nth-child(4) {
  top: 20%;
  left: 60%;
  animation-delay: 0.1s;
}
.firework.data-v-4978fed5:nth-child(5) {
  top: 70%;
  left: 60%;
  animation-delay: 0.3s;
}
@keyframes popIn-4978fed5 {
0% {
    transform: scale(0.5);
    opacity: 0;
}
100% {
    transform: scale(1);
    opacity: 1;
}
}
@keyframes explode-4978fed5 {
0% {
    box-shadow: 0 0 #ef4444, 0 0 #3b82f6, 0 0 #10b981, 0 0 #f59e0b, 0 0 #8b5cf6, 0 0 #ec4899, 0 0 #06b6d4, 0 0 #f43f5e;
    opacity: 1;
}
100% {
    box-shadow: -100rpx -100rpx #ef4444, 100rpx -100rpx #3b82f6, 100rpx 100rpx #10b981, -100rpx 100rpx #f59e0b, 0 -120rpx #8b5cf6, 120rpx 0 #ec4899, 0 120rpx #06b6d4, -120rpx 0 #f43f5e;
    opacity: 0;
}
}
